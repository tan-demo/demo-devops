# Keep LF line endings in the working tree on every platform. Shell scripts checked out with
# CRLF (the Windows default) fail with `\r` errors under bash — this prevents that.
* text=auto eol=lf

*.sh   text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.py   text eol=lf
*.tf   text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.drawio text eol=lf
*.svg  text eol=lf

*.png binary
