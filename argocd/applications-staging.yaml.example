apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: applications-staging
  namespace: argocd
spec:
  project: quote-api
  source:
    repoURL: https://github.com/tan-demo/demo-devops
    targetRevision: main
    path: argocd/applications/staging
    directory:
      recurse: true
  destination:
    server: https://kubernetes.default.svc
    namespace: argocd
  syncPolicy:
    automated:
      prune: true
      selfHeal: true
    syncOptions:
      - CreateNamespace=true
