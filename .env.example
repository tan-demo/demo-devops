# Copy to .env and adjust. .env is gitignored (never commit real secrets).

# GitHub owner — used for GHCR image (ghcr.io/<owner>/quote-api) and ArgoCD repoURL.
# Auto-detected from `git remote` by scripts if unset.
GH_OWNER=tan-demo

# Optional: only needed while the repo is PRIVATE so ArgoCD can read it.
# Read-only Personal Access Token (repo scope). Leave empty once repo is public.
GITHUB_TOKEN=
